APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

API_HTTP_TIMEOUT=15
API_HTTP_CONNECT_TIMEOUT=5

# CatalogoAPI: usar un puerto distinto al del catálogo web (php artisan serve es de un solo hilo).
# Recomendado: API en 8000, catálogo Laravel en 8001.
PRODUCTOS_API_URL=http://127.0.0.1:8000/api

# Configuración del módulo de autenticación API (ajusta endpoints según tu backend)
AUTH_API_URL=http://127.0.0.1:8000/api
AUTH_API_REGISTER_ENDPOINT=/register
AUTH_API_LOGIN_ENDPOINT=/login
AUTH_API_LOGOUT_ENDPOINT=/logout
AUTH_API_PROFILE_ENDPOINT=/profile
AUTH_API_AVATAR_ENDPOINT=/profile/avatar
AUTH_API_PASSWORD_ENDPOINT=/profile/password

# Configuración del módulo de pedidos API
ORDERS_API_URL=http://127.0.0.1:8000/api
ORDERS_API_INDEX_ENDPOINT=/orders
ORDERS_API_STORE_ENDPOINT=/orders
ORDERS_API_SHOW_ENDPOINT=/orders/{id}
ORDERS_API_CANCEL_ENDPOINT=/orders/{id}/cancel
ORDERS_API_PAYMENT_PREPARE_ENDPOINT=/orders/{id}/payments/prepare
ORDERS_API_PAYMENT_CONFIRM_ENDPOINT=/orders/{id}/payments/confirm
ORDERS_API_PAYMENT_CHECKOUT_SESSION_ENDPOINT=/orders/{id}/payments/checkout-session
ORDERS_API_PAYMENT_CHECKOUT_VERIFY_ENDPOINT=/orders/{id}/payments/checkout-verify
ORDERS_API_COUPON_VALIDATE_ENDPOINT=/coupon/validate
